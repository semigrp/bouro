{
  "name": "@semigrp/boros",
  "version": "0.2.0",
  "description": "A local-first ontology-backed knowledge graph and epistemic ledger for agent loops.",
  "type": "module",
  "bin": {
    "boros": "./dist/bin/boros.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && chmod +x dist/bin/boros.js",
    "test": "pnpm run build && node --test dist/test/*.test.js",
    "doctor": "pnpm run build && node ./dist/bin/boros.js doctor",
    "demo": "pnpm run build && node ./dist/bin/boros.js demo",
    "audit": "pnpm run build && node ./dist/bin/boros.js audit"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.8.3"
  }
}
